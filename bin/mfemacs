#!/bin/bash
# -*- Mode: Shell-script; -*-
#
# This is a small wrapper to run emacs or emacsclient.
set -x

# I am unable to get emacsclient working in remote desktop sessions on
# Linux/Wayland as the client is unable to connect with the emacs server
# reliably.  Unclear if this is a remote desktop or wayland problem.
if [ "$OS" == 'Linux' -a "$CHROME_REMOTE_DESKTOP_SESSION" == '1' -a "$XDG_SESSION_TYPE" == 'wayland' ]; then
  exec emacs "$@"
fi

emacsclient="emacsclient"
if [ "$OS" == 'Darwin' ]; then
  emacsclient="/Applications/Emacs.app/Contents/MacOS/bin/emacsclient";
fi

# Use -c to create a new graphical frame
# -a launches emacs in daemon mode if it isn't already running.
# -r avoids launching extra frames
# Do NOT use -n here if you want git to wait.
exec "$emacsclient" -r -c -a "" "$@"
